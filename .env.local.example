# Private application pages (/review/a, /review/n)
PRIVATE_AUTH_SECRET=replace_with_a_long_random_string
REVIEW_A_PASSWORD=your_review_a_password
REVIEW_N_PASSWORD=your_review_n_password

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
